# NextTrack Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Django Core Settings
# =============================================================================

# Secret key for cryptographic signing. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-real-secret-key

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# PostgreSQL Database
# =============================================================================

# Database name
POSTGRES_DB=music_db

# Database user
POSTGRES_USER=music_user

# Database password -- use a strong password in production
POSTGRES_PASSWORD=change-me

# Database host (use 'db' for Docker Compose, 'localhost' for local dev)
POSTGRES_HOST=db

# Database port
POSTGRES_PORT=5432

# =============================================================================
# Redis (used by Celery task queue and Django caching)
# =============================================================================

# Full Redis URL
REDIS_URL=redis://redis:6379/0

# Redis hostname (use 'redis' for Docker Compose, 'localhost' for local dev)
REDIS_HOST=redis

# =============================================================================
# Spotify API Credentials (Required for hybrid search and track ingestion)
# =============================================================================
# Register an app at https://developer.spotify.com/dashboard to get these.
#
# 1. Log in with your Spotify account (or create one)
# 2. Click "Create App"
# 3. Fill in the app details:
#    - App name: NextTrack (or any name you prefer)
#    - App description: Music recommendation engine
#    - Redirect URI: http://localhost:8000/spotify/callback/
# 4. Copy the Client ID and Client Secret from your app dashboard
#
# Without these credentials the system still works using the local database
# (CSV data). Spotify integration enables infinite search scope, on-demand
# audio feature fetching, and background harvesting.

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# =============================================================================
# Last.fm API (Optional -- enables tag-based boosts in recommendations)
# =============================================================================
# Get an API key at https://www.last.fm/api/account/create

LASTFM_API_KEY=

# =============================================================================
# Genius API (Optional -- enables lyrics-related features)
# =============================================================================
# Get an access token at https://genius.com/api-clients

GENIUS_ACCESS_TOKEN=
